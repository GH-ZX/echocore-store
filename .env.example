# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Supabase — required for auth, catalog, orders, and admin
# Create a project at https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production site (GitHub Actions secrets — optional for local .env):
#   VITE_SITE_DOMAIN=www.yourdomain.com
#   VITE_BASE_PATH=/
# Or full origin override:
#   VITE_AUTH_SITE_URL=https://www.yourdomain.com
#
# GitHub Pages (no custom domain):
#   Site URL: https://YOUR_USER.github.io/echocore-store
#   Redirect URLs:
#     https://YOUR_USER.github.io/echocore-store/login
#     https://YOUR_USER.github.io/echocore-store/**
#     http://localhost:5173/login
#
# Custom domain:
#   Site URL: https://www.yourdomain.com
#   Redirect URLs:
#     https://www.yourdomain.com/login
#     https://www.yourdomain.com/**
#     http://localhost:5173/login
#
# Providers: enable Email (OTP) + Google (OAuth client from Google Cloud Console)

# Optional — admin game image search (SteamGridDB / RAWG)
VITE_STEAMGRIDDB_API_KEY=
VITE_RAWG_API_KEY=

# Developer testing (admin dashboard → Developer tab)
# VITE_MOCK_FULFILLMENT=true  # skip real G2Bulk on purchase; use mock fulfillment in dashboard
# Run supabase_notifications_v2_migration.sql + v3 in Supabase SQL Editor

# G2Bulk — server/edge only (NEVER use VITE_ prefix). Also set in Supabase Edge Function secrets.
# G2BULK_API_KEY=
# G2BULK_CRON_SECRET=  # random secret for daily auto-sync cron (also in Supabase Vault as g2bulk_cron_secret)