# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Supabase — required for auth, catalog, orders, and admin
# Create a project at https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production site (GitHub Actions secrets — also fine in local .env):
#   VITE_SITE_DOMAIN=www.echocore412.com
#   VITE_BASE_PATH=/
# Or full origin override:
#   VITE_AUTH_SITE_URL=https://www.echocore412.com
#
# Live site: https://www.echocore412.com
# DNS / apex cleanup: docs/domain-dns.md
# Supabase Auth → URL configuration:
#   Site URL: https://www.echocore412.com
#   Redirect URLs:
#     https://www.echocore412.com/login
#     https://www.echocore412.com/**
#     http://localhost:5173/login
#
# Providers: enable Email (OTP) + Google (OAuth client from Google Cloud Console)

# Game images: IGDB credentials are set in Admin → Products (not env). See docs/igdb-api.md

# Developer testing (admin dashboard → Developer tab)
# VITE_MOCK_FULFILLMENT=true  # skip real G2Bulk on purchase; use mock fulfillment in dashboard
# Run supabase_notifications_v2_migration.sql + v3 in Supabase SQL Editor

# G2Bulk — server/edge only (NEVER use VITE_ prefix). Also set in Supabase Edge Function secrets.
# G2BULK_API_KEY=
# G2BULK_CRON_SECRET=  # random secret for daily auto-sync cron (also in Supabase Vault as g2bulk_cron_secret)